@namespace LumexUI
@inherits LumexComponentBase

@using S = ProgressSlots

<div class="@GetStyles( nameof( S.Base ) )"
     data-slot="base"
     data-indeterminate="@IsIndeterminate"
     data-disabled="@IsDisabled"
     role="progressbar"
     aria-valuenow="@(IsIndeterminate ? null : ((int)ClampedValue).ToString())"
     aria-valuemin="@((int)MinValue)"
     aria-valuemax="@((int)MaxValue)"
     aria-label="@ComputedAriaLabel"
     aria-valuetext="@ValueText"
     @attributes="@AdditionalAttributes">

    @if( !string.IsNullOrEmpty( Label ) || ShowValueLabel )
    {
        <div class="@GetStyles( nameof( S.LabelWrapper ) )"
             data-slot="labelWrapper">
            @if( !string.IsNullOrEmpty( Label ) )
            {
                <span class="@GetStyles( nameof( S.Label ) )"
                      data-slot="label">
                    @Label
                </span>
            }

            @if( ShowValueLabel && !IsIndeterminate )
            {
                <span class="@GetStyles( nameof( S.Value ) )"
                      data-slot="value">
                    @ValueText
                </span>
            }
        </div>
    }

    <div class="@GetStyles( nameof( S.Track ) )"
         data-slot="track">
        <div class="@GetStyles( nameof( S.Indicator ) )"
             data-slot="indicator"
             style="width: @IndicatorWidth">
        </div>
    </div>
</div>
