@page "/docs/components/progress-bar"
@layout DocsContentLayout

@using LumexUI.Docs.Client.Pages.Components.ProgressBar.PreviewCodes

<DocsSection Title="Usage">
    <Usage />

    <DocsSection Title="Sizes">
        <p>Use the <code>Size</code> parameter to control the height of the progress bar.</p>
        <Sizes />
    </DocsSection>

    <DocsSection Title="Colors">
        <p>Use the <code>Color</code> parameter to set the color of the progress bar.</p>
        <Colors />
    </DocsSection>

    <DocsSection Title="Radius">
        <p>Use the <code>Radius</code> parameter to control the border radius of the progress bar.</p>
        <Radii />
    </DocsSection>

    <DocsSection Title="Loading Bar">
        <p>
            Use the <code>IsLoadingBar</code> parameter to display an animated loading indicator.
            When enabled, the progress bar will show an infinite loading animation instead of a specific progress value.
        </p>
        <LoadingBar />
    </DocsSection>

    <DocsSection Title="Label">
        <p>
            Use the <code>ShowLabel</code> parameter to display the progress percentage.
            You can also use <code>LabelContent</code> to provide custom label content.
        </p>
        <Label />

        <DocsSection Title="Inline Label">
            <p>
                Use the <code>IsLabelInline</code> parameter to display the label inside the progress bar.
            </p>
            <InlineLabel />
        </DocsSection>

        <DocsSection Title="Position">
            <p>
                Use the <code>LabelPosition</code> parameter to control the label position (Start, Center, or End) when <code>IsLabelInline</code> is enabled.
            </p>
            <Position />
        </DocsSection>
    </DocsSection>
</DocsSection>

<DocsSection Title="Custom Styles">
    <div>
        <h4 class="font-semibold">ProgressBar</h4>
        <ul>
            <li><code>Class</code>: The CSS class names to style the progress bar track.</li>
            <li><code>Classes</code>: The CSS class names to style the progress bar slots.</li>
        </ul>
    </div>
    <CustomStyles />
</DocsSection>

<DocsApiSection Components="@_apiComponents" />

@code {
    [CascadingParameter] private DocsContentLayout Layout { get; set; } = default!;

    private readonly Heading[] _headings = new Heading[]
    {
        new("Usage", [
            new("Sizes"),
            new("Colors"),
            new("Radius"),
            new("Loading Bar"),
            new("Label", [
                new("Inline Label"),
                new("Position")
            ]),
        ]),
        new("Custom Styles"),
        new("API")
    };

    private readonly string[] _apiComponents = new string[]
    {
        nameof(LumexProgressBar)
    };

    protected override void OnInitialized()
    {
        Layout.Initialize(
            title: "ProgressBar",
            category: "Components",
            description: "Progress bars display the progress of a task or operation, and can also be used as animated loading indicators.",
            headings: _headings,
            linksProps: new ComponentLinksProps("ProgressBar", isServer: false)
        );
    }
}
